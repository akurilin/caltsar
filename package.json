{
  "name": "caltsar2",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "engines": {
    "node": "16.x"
  },
  "scripts": {
    "dev": "nodemon -r dotenv/config src/server.ts",
    "build": "rm -rf ./dist/ && npx prettier --check . && npx eslint . --ext .js,.jsx,.ts,.tsx && tsc",
    "test": "rm -rf ./dist/ && PGDATABASE=caltsar_test PORT=4000 jest --detectOpenHandles --passWithNoTests",
    "test:watch": "PGDATABASE=caltsar_test PORT=4000 jest --detectOpenHandles --watchAll",
    "prod": "node -r dotenv/config dist/server.js",
    "ngrok": "ngrok http --region=us --hostname=app.akurilin.com 3000",
    "shellcheck": "find ./scripts/ -name \"*.sh\" -exec shellcheck -s sh {} \\;",
    "db:psql:dev": "docker exec -it postgres13 psql -U postgres -d caltsar_dev",
    "db:psql:test": "docker exec -it postgres13 psql -U postgres -d caltsar_test",
    "db:psql:prod": "docker exec -it postgres13 psql $(heroku config:get DATABASE_URL -a calentsar)",
    "db:migrate:dev": "PGDATABASE=caltsar_dev ./scripts/update-changelog.sh",
    "db:migrate:local": "PGDATABASE=caltsar_dev ./scripts/update-changelog.sh && PGDATABASE=caltsar_test ./scripts/update-changelog.sh",
    "db:migrate:prod": "DATABASE_URL=$(heroku config:get DATABASE_URL -a calentsar) python3 scripts/update-changelog-prod.py",
    "db:reset": "./scripts/reset-local-db.sh",
    "db:rollback": "PGDATABASE=caltsar_dev ./scripts/rollback-changelog.sh && PGDATABASE=caltsar_test ./scripts/rollback-changelog.sh",
    "db:seed": "PGDATABASE=caltsar_dev ./scripts/seed-db.sh",
    "db:truncate": "PGDATABASE=caltsar_dev ./scripts/truncate-db.sh"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@googleapis/calendar": "^1.0.1",
    "connect-pg-simple": "^7.0.0",
    "cors": "^2.8.5",
    "dayjs": "^1.10.7",
    "express": "^4.17.1",
    "express-session": "^1.17.2",
    "gaxios": "^4.3.2",
    "helmet": "^4.6.0",
    "morgan": "^1.10.0",
    "nodemon": "^2.0.13",
    "passport": "^0.5.0",
    "passport-custom": "^1.1.1",
    "passport-google-oauth2": "^0.2.0",
    "pg": "^8.7.1",
    "pg-format": "^1.0.4",
    "ts-node": "^10.2.1",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^4.2.4",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/express-session": "^1.17.4",
    "@types/jest": "^27.0.2",
    "@types/morgan": "^1.9.3",
    "@types/passport": "^1.0.7",
    "@types/passport-google-oauth2": "^0.1.4",
    "@types/passport-google-oauth20": "^2.0.11",
    "@types/pg": "^8.6.1",
    "@types/pg-format": "^1.0.2",
    "@types/supertest": "^2.0.11",
    "@types/uuid": "^8.3.3",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "dotenv": "^10.0.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "jest": "^27.2.5",
    "prettier": "2.4.1",
    "supertest": "^6.1.6",
    "ts-jest": "^27.0.7",
    "typescript": "^4.4.3"
  }
}
